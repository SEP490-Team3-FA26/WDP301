# ============================
# DATABASE (Supabase PostgreSQL)
# ============================
DATABASE_URL=postgresql://user:password@host:port/database

# MongoDB Connection
MONGODB_CONNECTION_STRING=mongodb+srv://user:password@host/database
MONGODB_ATLAS_URI=mongodb+srv://user:password@host/database

# ============================
# SUPABASE KEYS (Dùng khi cần SDK)
# ============================
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# ============================
# JWT AUTH
# ============================
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=3600s

# ============================
# REDIS CACHE
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================
# KAFKA MESSAGE BROKER
# ============================
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=wdp301-consumers

# ============================
# GENERAL
# ============================
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001


# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
JWT_SECRET_KEY=your_jwt_secret_key
GOOGLE_CLIENT_SECRET=your_google_client_secret

# PayOS
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

EXPO_PUBLIC_AI_PROVIDER=groq
EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key
COHERE_API_KEY=your_cohere_api_key

MONGODB_URI=mongodb+srv://user:password@host/database

# Email Configuration (Gmail SMTP) — chỉ dùng cho dev local nếu chưa có SQS.
# Production: email gửi qua SQS → Lambda → SES (xem section AWS bên dưới).
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password

# ============================================================
# AWS (S3 / SQS / SES) — production
# Trên EC2: KHÔNG cần access key, credentials lấy từ IAM instance role.
# Local dev: dùng `aws configure` hoặc set AWS_ACCESS_KEY_ID/SECRET nếu muốn test.
# ============================================================
AWS_REGION=ap-southeast-1
# Bucket lưu ảnh (lấy từ `terraform output s3_images_bucket`)
S3_IMAGES_BUCKET=wdp301-images-dev-065320271583
# Bucket lưu log
S3_LOGS_BUCKET=wdp301-logs-dev-065320271583
# Hàng đợi email (lấy từ `terraform output sqs_email_queue_url`)
# Nếu để trống → auth-service fallback mock (in OTP ra console, không gửi mail).
SQS_EMAIL_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/065320271583/wdp301-dev-email
# Địa chỉ gửi (đã verify trong SES)
SES_FROM_EMAIL=no-reply@abcpharmacy.store

OPEN_ROUTER_API=your_open_router_api_key
