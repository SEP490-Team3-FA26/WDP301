      "sourceRoot": "apps/wdp301-backend/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wdp301-backend/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    },
    "inventory-service": {
      "type": "application",
      "root": "apps/inventory-service",
      "entryFile": "main",
      "sourceRoot": "apps/inventory-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/inventory-service/tsconfig.app.json"
      }
    },
    "supplier-service": {
      "type": "application",
      "root": "apps/supplier-service",
      "entryFile": "main",
      "sourceRoot": "apps/supplier-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/supplier-service/tsconfig.app.json"
      }
    }
  }
}