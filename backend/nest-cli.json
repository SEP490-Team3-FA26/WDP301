{
  "monorepo": true,
  "root": "apps/wdp301-backend",
  "sourceRoot": "apps/wdp301-backend/src",
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "apps/wdp301-backend/tsconfig.app.json"
  },
  "projects": {
    "wdp301-backend": {
      "type": "application",
      "root": "apps/wdp301-backend",
