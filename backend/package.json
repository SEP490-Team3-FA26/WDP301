{
  "name": "wdp301-backend",
  "version": "0.1.0",
  "description": "NestJS backend for WDP301 enterprise platform",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/wdp301-backend/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./apps/api-gateway/test/jest-e2e.json --detectOpenHandles",
    "// --- MICROSERVICES COMMANDS ---": "",
    "start:gateway": "nest start api-gateway --watch",
    "start:auth": "nest start auth-service -b swc --watch",
    "start:user": "nest start user-service -b swc --watch",
    "start:inventory": "nest start inventory-service -b swc --watch",
    "start:supplier": "nest start supplier-service -b swc --watch",
    "start:orders": "nest start orders-service -b swc --watch",
    "dev:all": "npx concurrently --kill-others \"npm run start:gateway\" \"npm run start:auth\" \"npm run start:user\" \"npm run start:inventory\" \"npm run start:supplier\" \"npm run start:orders\"",
    "// --- PRODUCTION BUILD & START ---": "",
    "build:all": "nest build api-gateway && nest build auth-service && nest build user-service && nest build inventory-service && nest build supplier-service && nest build orders-service",
    "start:all:prod": "npx concurrently --kill-others \"node dist/apps/api-gateway/main\" \"node dist/apps/auth-service/main\" \"node dist/apps/user-service/main\" \"node dist/apps/inventory-service/main\" \"node dist/apps/supplier-service/main\" \"node dist/apps/orders-service/main\"",
    "inspect": "ts-node --transpile-only scripts/inspect-db.ts",
    "test:expiration": "ts-node --transpile-only scripts/test-expiration-action.ts",
    "db:clean-medicines": "ts-node --transpile-only scripts/clean-medicines.ts",
    "db:seed-prescriptions": "ts-node --transpile-only scripts/seed-prescriptions.ts",
    "// --- INFRASTRUCTURE ---": "",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "infra:logs": "docker-compose logs -f kafka redis"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/client-sqs": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "@huggingface/inference": "^4.13.23",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.22",
    "@nestjs/mongoose": "^10.0.4",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.22",
    "@payos/node": "^2.0.5",
    "@supabase/supabase-js": "^2.106.2",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^5.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "concurrently": "^9.2.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.8.0",
    "mongoose": "^8.2.3",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.30",
    "wdp301-workspace": "file:.."
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
