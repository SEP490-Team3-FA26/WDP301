        <mxCell id="db" value="MongoDB (User &amp; Token Collections)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;" vertex="1" parent="1">
          <mxGeometry x="2080" y="40" width="100" height="1600" as="geometry"/>
        </mxCell>
        <mxCell id="email_svc" value="SqsEmailService (AWS SES)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;" vertex="1" parent="1">
          <mxGeometry x="2420" y="40" width="100" height="1600" as="geometry"/>
        </mxCell>
        <mxCell id="act0" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="db">
          <mxGeometry x="45" y="340" width="10" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="act1" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="db">
          <mxGeometry x="45" y="500" width="10" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="act2" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="db">
          <mxGeometry x="45" y="600" width="10" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="act3" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="svc">
          <mxGeometry x="45" y="290" width="10" height="410" as="geometry"/>
        </mxCell>
        <mxCell id="act4" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="ms">
          <mxGeometry x="45" y="240" width="10" height="510" as="geometry"/>
        </mxCell>
        <mxCell id="act5" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="kafka">
          <mxGeometry x="45" y="190" width="10" height="610" as="geometry"/>
        </mxCell>
        <mxCell id="act6" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="gw">
          <mxGeometry x="45" y="140" width="10" height="710" as="geometry"/>
        </mxCell>
        <mxCell id="act7" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="ui">
          <mxGeometry x="45" y="90" width="10" height="810" as="geometry"/>
        </mxCell>
        <mxCell id="act8" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="email_svc">
          <mxGeometry x="45" y="1360" width="10" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="act9" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="svc">
          <mxGeometry x="45" y="1210" width="10" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="act10" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="gw">
          <mxGeometry x="45" y="1060" width="10" height="450" as="geometry"/>
        </mxCell>
        <mxCell id="act11" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="ui">
          <mxGeometry x="45" y="1010" width="10" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="act12" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="kafka">
          <mxGeometry x="45" y="1110" width="10" height="450" as="geometry"/>
        </mxCell>
        <mxCell id="act13" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="ms">
          <mxGeometry x="45" y="1160" width="10" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="act14" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="db">
          <mxGeometry x="45" y="1260" width="10" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="m0" value="1. Enter 6-digit OTP code &amp; click 'Activate Account'" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=0.5;exitY=0.0563;entryX=0;entryY=0.0;" edge="1" parent="1" source="user" target="act7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="2. POST /api/auth/verify-email {email, otp}" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.0617;entryX=0;entryY=0.0;" edge="1" parent="1" source="act7" target="act6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="3. sendKafkaMessage('auth.verify.email', VerifyEmailDto)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.0704;entryX=0;entryY=0.0;" edge="1" parent="1" source="act6" target="act5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m3" value="4. Consume topic 'auth.verify.email'" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.082;entryX=0;entryY=0.0;" edge="1" parent="1" source="act5" target="act4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="5. authService.verifyEmail(email, token)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.098;entryX=0;entryY=0.0;" edge="1" parent="1" source="act4" target="act3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m5" value="6. findOne({userId: email, token, type: 'EMAIL_VERIFICATION', isUsed: false})" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.122;entryX=0;entryY=0.0;" edge="1" parent="1" source="act3" target="act0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m6" value="7. Return VerificationToken document" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.2439;" edge="1" parent="1" source="act0" target="act3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="note7" value="Validate token expiration (expiresAt &gt; new Date())" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1810" y="460" width="280" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m8" value="8. Update User (isEmailVerified = true)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.5122;entryX=0;entryY=0.0;" edge="1" parent="1" source="act3" target="act1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m9" value="9. User record updated successfully" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.6341;" edge="1" parent="1" source="act1" target="act3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m10" value="10. Update VerificationToken (isUsed = true)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.7561;entryX=0;entryY=0.0;" edge="1" parent="1" source="act3" target="act2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m11" value="11. Token marked as used" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.878;" edge="1" parent="1" source="act2" target="act3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m12" value="12. {message: 'Email verification successful!'}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.902;" edge="1" parent="1" source="act3" target="act4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m13" value="13. Send response to Kafka Reply Topic" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.918;" edge="1" parent="1" source="act4" target="act5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m14" value="14. Receive Kafka response" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.9296;" edge="1" parent="1" source="act5" target="act6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m15" value="15. HTTP 200 OK {message: 'Email verification successful!'}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.9383;" edge="1" parent="1" source="act6" target="act7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m16" value="16. Display success message &amp; redirect to Login page" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=0.5;entryY=0.5625;" edge="1" parent="1" source="act7" target="user">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="note17" value="--- RESEND OTP FLOW ---" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="110" y="970" width="191" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m18" value="17. Click 'Resend OTP'" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=0.5;exitY=0.6312;entryX=0;entryY=0.0;" edge="1" parent="1" source="user" target="act11">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m19" value="18. POST /api/auth/resend-verification {email}" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.0909;entryX=0;entryY=0.0;" edge="1" parent="1" source="act11" target="act10">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m20" value="19. sendKafkaMessage('auth.resend.verification', Dto)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.1111;entryX=0;entryY=0.0;" edge="1" parent="1" source="act10" target="act12">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m21" value="20. Consume topic 'auth.resend.verification'" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.1111;entryX=0;entryY=0.0;" edge="1" parent="1" source="act12" target="act13">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m22" value="21. resendVerificationOtp(email)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.125;entryX=0;entryY=0.0;" edge="1" parent="1" source="act13" target="act9">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m23" value="22. deleteMany({userId: email, type: 'EMAIL_VERIFICATION'})" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.2;entryX=0;entryY=0.0;" edge="1" parent="1" source="act9" target="act14">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m24" value="23. create({token: newOtp, expiresAt, type: 'EMAIL_VERIFICATION'})" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.4;entryX=0;entryY=0.1667;" edge="1" parent="1" source="act9" target="act14">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m25" value="24. sendEmail({to: email, subject: 'New Activation OTP', otp})" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.6;entryX=0;entryY=0.0;" edge="1" parent="1" source="act9" target="act8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m26" value="25. SQS Email Queued / Sent OK" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.8;" edge="1" parent="1" source="act8" target="act9">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m27" value="26. Return response via Kafka" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.8889;" edge="1" parent="1" source="act9" target="act10">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m28" value="27. HTTP 200 OK {message: 'New OTP code sent'}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.9091;" edge="1" parent="1" source="act10" target="act11">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
