        <mxCell id="m0" value="1. Upload multi-page prescription photos" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=0.5;exitY=0.1;entryX=0;entryY=0.0;" edge="1" parent="1" source="pharmacist" target="act6">
