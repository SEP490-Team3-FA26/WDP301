        <mxCell id="m1" value="2. POST /api/prescriptions/scan-ai (multiPageImages)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.0694;entryX=0;entryY=0.0;" edge="1" parent="1" source="act6" target="act5">
