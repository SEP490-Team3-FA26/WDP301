        </mxCell>
        <mxCell id="m6" value="7. sendKafkaMessage('inventory.fifo.allocate', activeIngredients)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.4231;entryX=0;entryY=0.0;" edge="1" parent="1" source="act4" target="act3">
