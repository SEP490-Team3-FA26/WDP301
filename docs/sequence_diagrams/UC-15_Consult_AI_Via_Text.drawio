        <mxCell id="m7" value="8. Return Consultation Response JSON" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#999999;fontColor=#999999;exitX=0;exitY=1.0;entryX=1;entryY=0.8571;" edge="1" parent="1" source="act2" target="act3">
          <mxGeometry relative="1" as="geometry"/>
