        <mxCell id="act0" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="med_db">
          <mxGeometry x="45" y="240" width="10" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="act1" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;outlineConnect=0;fillColor=#ffffff;" vertex="1" parent="groq_llm">
          <mxGeometry x="45" y="340" width="10" height="50" as="geometry"/>
