        <mxCell id="med_db" value="Medicine Knowledge Base" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=40;" vertex="1" parent="1">
          <mxGeometry x="1390" y="40" width="100" height="630" as="geometry"/>
