        </mxCell>
        <mxCell id="m0" value="1. Enter Symptom Question (e.g., 'Headache &amp; Mild Fever guidance')" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=0.5;exitY=0.1429;entryX=0;entryY=0.0;" edge="1" parent="1" source="customer" target="act4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="2. POST /api/ai/chat (prompt)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.1111;entryX=0;entryY=0.0;" edge="1" parent="1" source="act4" target="act3">
