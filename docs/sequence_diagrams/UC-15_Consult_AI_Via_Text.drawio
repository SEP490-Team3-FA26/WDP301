        <mxCell id="m3" value="4. RAG Vector Search for relevant OTC Drug Indications" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.2;entryX=0;entryY=0.0;" edge="1" parent="1" source="act2" target="act0">
