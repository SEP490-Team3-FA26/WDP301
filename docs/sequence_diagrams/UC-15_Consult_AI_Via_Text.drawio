        <mxCell id="m2" value="3. fetch('http://ai-service:8000/api/ai/chat')" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.1429;entryX=0;entryY=0.0;" edge="1" parent="1" source="act3" target="act2">
          <mxGeometry relative="1" as="geometry"/>
