          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m5" value="6. Request LLM Medical Consultation Response" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=1;exitY=0.6;entryX=0;entryY=0.0;" edge="1" parent="1" source="act2" target="act1">
          <mxGeometry relative="1" as="geometry"/>
